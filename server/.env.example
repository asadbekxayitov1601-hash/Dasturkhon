# ── Dasturkhon backend environment ──────────────────────────────────────────
# Copy this to `.env` on the server and fill in real values. Never commit .env.

# Neon Postgres — pooled connection string (used by the app at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Neon Postgres — DIRECT (non-pooled) connection (used by prisma db push/migrate)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Any long random string — signs login tokens. Generate: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string"

# Email via Brevo HTTP API (Railway/most hosts block SMTP). Get a key at brevo.com.
BREVO_API_KEY="xkeysib-..."
# Sender address — MUST be a Verified Sender in your Brevo account.
MAIL_FROM="dasturkhon.uz@gmail.com"
MAIL_FROM_NAME="Dasturkhon"

# Public site URL used in email links (e.g. password reset / follower alerts).
APP_URL="https://dasturkhon.uz"

# Allowed browser origin(s) for CORS — comma-separated. Your live domain.
FRONTEND_URL="https://dasturkhon.uz"

# Google sign-in (optional). Leave unset to hide the Google button.
GOOGLE_CLIENT_ID=""

# Port the Node API listens on (Caddy/nginx proxies /api to this). Default 4000.
PORT="4000"

# Optional: where the error log is written (defaults to server/logs/).
# LOG_DIR="/var/log/dasturkhon"
