generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  name          String?
  email         String         @unique
  passwordHash  String
  isAdmin       Boolean        @default(false)
  isPro         Boolean        @default(false)
  subType       String?
  subEndDate    DateTime?
  cardToken     String?
  cardLast4     String?
  bio           String?        // chef bio
  avatarUrl     String?        // chef avatar
  createdAt     DateTime       @default(now())
  pantryItems   PantryItem[]
  shoppingItems ShoppingItem[]
  recipes       Recipe[]
  favorites     Favorite[]
  reviews       Review[]
  // Follow relations
  following     Follow[]       @relation("follower")  // people this user follows
  followers     Follow[]       @relation("following") // people following this user
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int      // the user who follows
  followingId Int      // the user being followed
  follower    User     @relation("follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model PantryItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  name      String
  status    String
  category  String
  quantity  String?
  createdAt DateTime @default(now())
}

model ShoppingItem {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  name       String
  quantity   String
  recipeId   String?
  recipeName String?
  checked    Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Recipe {
  id           Int        @id @default(autoincrement())
  title        String
  image        String
  cookTime     String
  servings     Int
  category     String
  ingredients  String
  instructions String
  youtubeUrl   String?
  isPro        Boolean    @default(false)
  status       String     @default("pending")
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  favorites    Favorite[]
  reviews      Review[]
  views        RecipeView[]
  createdAt    DateTime   @default(now())
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, recipeId])
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  photoUrl  String?
  createdAt DateTime @default(now())

  @@unique([userId, recipeId])
}

model RecipeView {
  id        Int      @id @default(autoincrement())
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@index([recipeId])
  @@index([viewedAt])
}
