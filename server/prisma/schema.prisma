generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            Int            @id @default(autoincrement())
  name          String?
  email         String?        @unique // optional: phone-only accounts have no email
  phone         String?        // NEW: phone number (uniqueness enforced in app logic)
  phoneVerified Boolean        @default(false) // NEW: phone confirmed via SMS code
  telegramId       String?     // NEW: Telegram user id (uniqueness enforced in app logic)
  telegramUsername String?     // NEW: Telegram @username
  passwordHash  String?        // optional: Google-/phone-only accounts have no password
  googleId      String?        // NEW: linked Google account id (uniqueness enforced via email)
  emailVerified Boolean        @default(false) // NEW: email confirmed via code/Google
  isAdmin       Boolean        @default(false)
  isPro         Boolean        @default(false)
  subType       String?
  subEndDate    DateTime?
  cardToken     String?
  cardLast4     String?
  bio           String?        // NEW: chef bio
  avatarUrl     String?        // NEW: chef avatar
  socialLinks   String?        // NEW: JSON string of social media links
  lastSeen      DateTime?      // NEW: presence tracking for admin online count
  createdAt     DateTime       @default(now())
  pantryItems   PantryItem[]
  shoppingItems ShoppingItem[]
  recipes       Recipe[]
  favorites     Favorite[]
  reviews       Review[]
  likes         RecipeLike[]
  notifications Notification[]
  // Follow relations
  following     Follow[]       @relation("follower")  // people this user follows
  followers     Follow[]       @relation("following") // people following this user
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int      // the user who follows
  followingId Int      // the user being followed
  follower    User     @relation("follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model PantryItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  name      String
  status    String
  category  String
  quantity  String?
  createdAt DateTime @default(now())
}

model ShoppingItem {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  name       String
  quantity   String
  recipeId   String?
  recipeName String?
  checked    Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Recipe {
  id           Int        @id @default(autoincrement())
  title        String
  image        String
  cookTime     String
  servings     Int
  category     String
  ingredients  String
  instructions String
  youtubeUrl   String?
  isPro        Boolean    @default(false)
  orderable    Boolean    @default(false) // NEW: chef takes direct orders for this dish
  orderPhone   String?    // NEW: phone the chef entered for call-to-order (orderable only)
  status       String     @default("pending")
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  favorites    Favorite[]
  reviews      Review[]
  views        RecipeView[]
  likes        RecipeLike[]
  createdAt    DateTime   @default(now())
}

// In-app notification (e.g. a followed author published a new recipe).
// Actor/recipe info is denormalized so it survives deletes and needs no joins.
model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int      // recipient
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   @default("new_recipe")
  actorId     Int
  actorName   String?
  recipeId    Int?
  recipeTitle String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, recipeId])
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  photoUrl  String?
  createdAt DateTime @default(now())

  @@unique([userId, recipeId])
}

model RecipeView {
  id        Int      @id @default(autoincrement())
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@index([recipeId])
  @@index([viewedAt])
}

model RecipeLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId  Int
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  type      String   // "like" or "dislike"
  createdAt DateTime @default(now())

  @@unique([userId, recipeId])
  @@index([recipeId])
}

// Short-lived verification codes for signup / login 2FA / password reset.
// Stored in the DB (not memory) so they survive restarts and work across
// multiple server instances. type: "signup" | "login" | "reset".
model VerificationCode {
  id        Int      @id @default(autoincrement())
  email     String
  type      String
  code      String
  data      String?  // JSON payload (e.g. pending signup: name + passwordHash)
  userId    Int?     // for login/reset: the target user id
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, type])
}
